                calculateTravelModeDistanceAndTime(mode) {
                    //const totalDistance = this.result.map(item => item[`${mode}DistanceInMeters`]).reduce((prev, next) => prev + next);
                    //const averageDistanceInMeters = totalDistance / this.result.length;
                    //const averageDistance = Math.round(averageDistanceInMeters / 1000) + ' km';
                    const maxDistanceInMeters = Math.max.apply(Math, this.result.map(item => item[`${mode}DistanceInMeters`]));
                    const maxDistance = Math.round(maxDistanceInMeters / 1000).toString().replace('.', ',');
                    const minDistanceInMeters = Math.min.apply(Math, this.result.map(item => item[`${mode}DistanceInMeters`]));
                    const minDistance = Math.round(minDistanceInMeters / 1000).toString().replace('.', ',');
                    const medianDistanceInMeters = this.getMedian(this.result.map(item => item[`${mode}DistanceInMeters`]));
                    const medianDistance = Math.round(medianDistanceInMeters / 1000).toString().replace('.', ',');

                    //const totalTime = this.result.map(item => item[`${mode}TimeInSeconds`]).reduce((prev, next) => prev + next);
                    //const avgTimeInSeconds = totalTime / this.result.length;
                    //const averageTime = Math.round(avgTimeInSeconds / 60) + ' mins';
                    const maxTimeInSeconds = Math.max.apply(Math, this.result.map(item => item[`${mode}TimeInSeconds`]));
                    const maxTime = this.getFormattedDuration(maxTimeInSeconds);
                    const minTimeInSeconds = Math.min.apply(Math, this.result.map(item => item[`${mode}TimeInSeconds`]));
                    const minTime = this.getFormattedDuration(minTimeInSeconds);
                    const medianTimeInSeconds = this.getMedian(this.result.map(item => item[`${mode}TimeInSeconds`]));
                    const medianTime = this.getFormattedDuration(medianTimeInSeconds);
                    //Math.round(medianTimeInSeconds / 60) + ' mins';

                    return {
                        medianDistance: parseFloat(medianDistance),
                        medianTime: parseFloat(medianTime),
                        maxDistance: parseFloat(maxDistance),
                        maxTime: parseFloat(maxTime),
                        minDistance: parseFloat(minDistance),
                        minTime: parseFloat(minTime),
                    }
                },
                getMedian(arr) {
                    const mid = Math.floor(arr.length / 2),
                        nums = [...arr].sort((a, b) => a - b);
                    return arr.length % 2 !== 0 ? nums[mid] : (nums[mid - 1] + nums[mid]) / 2;
                },
                getCurrentTimeUTC() {
                    //RETURN:
                    //      = number of milliseconds between current UTC time and midnight of January 1, 1970
                    var tmLoc = new Date();
                    //The offset is in minutes -- convert it to ms
                    return tmLoc.getTime() + tmLoc.getTimezoneOffset() * 60000;
                },
                calculate() {
                    window.localStorage.setItem('destinations', this.destinations);

                    if (!this.currentMarkerLatlng) {
                        $.notify('Please select a destination on map', 'error');
                        return;
                    }

                    this.$validator.validateAll('frmModel').then((result) => {
                        if (result) {
                            this.blockUI();
                            this.result = [];
                            this.currentTravelMode = 'DRIVING';
                            this.currentTransitMode = 'BUS';
                            this.calculateTime(this.currentMarkerLatlng, 0);
                        }
                    }).catch(() => {

                    });

                },
                clearFilter() {
                    if (this.currentMarker) {
                        this.currentMarker.setMap(null);
                        this.currentMarker = null;
                    }
                    //this.drivingOptions = { departureTime: '', trafficModel: 'bestguess' };
                    //this.destinations = '';
                    //window.localStorage.setItem('destinations', this.destinations);
                    //this.travelMode = 'DRIVING';
                    this.result = [];
                    this.currentMarkerLatlng = null;
                    this.deleteMarkers();

                },
                clearAll() {
                    window.localStorage.setItem('destinations', this.destinations);
                    window.location.reload();
                },
                deleteMarkers() {
                    for (let i = 0; i < this.markersArray.length; i++) {
                        this.markersArray[i].setMap(null);
                    }

                    this.markersArray = [];
                },
                getFormattedDuration(secs) {

                    return Math.round(secs / 60);

                    const formatted = moment.utc(secs * 1000).format('HH:mm:ss');

                    let [hours, minutes, seconds] = formatted.split(':');
                    minutes = seconds > 30 ? parseInt(minutes) + 1 : minutes;
                    hours = parseInt(hours);
                    minutes = parseInt(minutes);
                    const result = hours > 0 ? `${hours} hour${hours > 1 ? 's' : ''}` : '';

                    return `${result} ${minutes} min${minutes > 1 ? 's' : ''}`
                },
                distanceGridToolbarClick(args) {
                    if (args.item.id === 'locationDistances_excelexport') { // 'Grid_excelexport' -> Grid component id + _ + toolbar item name
                        let appendExcelExportProperties = {
                            fileName: "Distances & Time from Origin to Destination.xlsx"
                        };
                        var locationDistanceGrid = document.getElementById("locationDistances").ej2_instances[0];
                        locationDistanceGrid.excelExport(appendExcelExportProperties);
                    }
                },
                statisticsGridToolbarClick(args) {
                    if (args.item.id === 'statisticsGrid_excelexport') { // 'Grid_excelexport' -> Grid component id + _ + toolbar item name
                        let appendExcelExportProperties = {
                            fileName: "Statistics of Distance & Time.xlsx"
                        };
                        var statisticsGrid = document.getElementById("statisticsGrid").ej2_instances[0];
                        statisticsGrid.excelExport(appendExcelExportProperties);
                    }
                },
                skipTake(array, skip, take) {

                    let len = array.length;
                    if ((skip + take) > len) {
                        take = len - skip;
                    }

                    let newArray = [];
                    for (i = skip; i < (skip + take); i++) {
                        newArray.push(array[i]);
                    }

                    return newArray;
                },
                blockUI(ctrl) {
                    ctrl = this.isNullOrEmpty(ctrl) ? 'body' : ctrl;
                    $(ctrl).loading({
                        stoppable: false,
                        zIndex: 10051,
                        message: 'Please wait ...'
                    });
                },
                unBlockUI(ctrl) {
                    ctrl = this.isNullOrEmpty(ctrl) ? 'body' : ctrl;
                    $(ctrl).loading('stop');
                },
                isNullOrEmpty(str) {
                    if (typeof str === 'undefined')
                        return true;

                    if (str === null)
                        return true;

                    var string = str.toString();
                    if (!string)
                        return true;
                    return string === null || string.match(/^ *$/) !== null;
                }
            }
        });

