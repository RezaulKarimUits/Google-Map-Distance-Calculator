@{
    ViewData["Title"] = "Home Page";
}

<style>
    #map {
        position: relative;
        padding-bottom: 26.25%;
        padding-top: 30px;
        height: 360px;
        overflow: hidden;
    }

    .mx-input {
        height: calc(1.5em + .5rem + 2px);
        padding: .375rem .75rem;
    }

    #statTable {
        font-size: 14px;
    }

    #locationDistances .e-content {
        max-height: calc(100vh - 450px);
    }
</style>


<div id="vc_app" v-cloak>
    <div class="container-fluid">
        <div class="row">
            <div class="col-4">
                <form v-on:submit.prevent="calculate" data-vv-scope="frmModel">
                    <div class="form-row">
                        @*    <div class="form-group col-4">
                                <label for="inputEmail4">Travel Mode</label>
                                <select class="form-control form-control-sm" v-model="travelMode" id="exampleFormControlSelect1">
                                    <option v-for="mode in travelModes" :value="mode">{{mode}}</option>
                                </select>
                            </div>
                        *@
                        <div class="form-group col-6">
                            <label for="departureTime">Departure time</label>
                            <ejs-datetimepicker :min="minDateForDeparture" v-model="departureTime" :placeholder="'Departure time'"></ejs-datetimepicker>
                        </div>
                        @*
                            <div class="form-group col-4" v-if="travelMode=='DRIVING'">
                                <label for="inputEmail4">Travel Mode</label>
                                <select class="form-control form-control-sm" v-model="drivingOptions.trafficModel" id="exampleFormControlSelect1">
                                    <option v-for="model in trafficModels" :value="model">{{model}}</option>
