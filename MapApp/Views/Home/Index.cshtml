                calculateStatistics() {

                    const { medianDistance: medianDrivingDistance, medianTime: medianDrivingTime, maxDistance: maxDrivDistance, minDistance: minDrivDistance, maxTime: maxDrivTime, minTime: minDriveTime } = this.calculateTravelModeDistanceAndTime('driving');
                    const { medianDistance: medianWalkingDistance, medianTime: medianWalkingTime, maxDistance: maxWalkDistance, minDistance: minWalkDistance, maxTime: maxWalkTime, minTime: minWalkTime } = this.calculateTravelModeDistanceAndTime('walking');
                    const { medianDistance: medianBicyclingDistance, medianTime: medianBicyclingTime, maxDistance: maxBicycleDistance, minDistance: minBicycleDistance, maxTime: maxBicycleTime, minTime: minBicycleTime } = this.calculateTravelModeDistanceAndTime('bicycling');
                    const { medianDistance: medianBusDistance, medianTime: medianBusTime, maxDistance: maxBusDistance, minDistance: minBusDistance, maxTime: maxBusTime, minTime: minBusTime } = this.calculateTravelModeDistanceAndTime('bus');
                    const { medianDistance: medianRailDistance, medianTime: medianRailTime, maxDistance: maxRailDistance, minDistance: minRailDistance, maxTime: maxRailTime, minTime: minRailTime } = this.calculateTravelModeDistanceAndTime('rail');
                    const { medianDistance: medianSubwayDistance, medianTime: medianSubwayTime, maxDistance: maxSubwayDistance, minDistance: minSubwayDistance, maxTime: maxSubwayTime, minTime: minSubwayTime } = this.calculateTravelModeDistanceAndTime('subway');
                    const { medianDistance: medianTrainDistance, medianTime: medianTrainTime, maxDistance: maxTrainDistance, minDistance: minTrainDistance, maxTime: maxTrainTime, minTime: minTrainTime } = this.calculateTravelModeDistanceAndTime('train');
                    const { medianDistance: medianTramDistance, medianTime: medianTramTime, maxDistance: maxTramDistance, minDistance: minTramDistance, maxTime: maxTramTime, minTime: minTramTime } = this.calculateTravelModeDistanceAndTime('tram');

