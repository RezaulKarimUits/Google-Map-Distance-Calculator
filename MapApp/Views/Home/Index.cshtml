@section Scripts{

    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCTwbQei5fpFrm2RDm9VzjqIblbUOMigWo"></script>
    <script src="~/lib/moment.min.js"></script>
    <script>
        const { GridPlugin, Sort, Filter, Toolbar, ExcelExport } = ejs.grids;
        const { DateTimePickerPlugin } = ejs.calendars;

        Vue.use(DateTimePickerPlugin);
        Vue.use(GridPlugin);
        Vue.use(VeeValidate);


        const svgMarker = {
            path: "M256,0C161.896,0,85.333,76.563,85.333,170.667c0,28.25,7.063,56.26,20.49,81.104L246.667,506.5    c1.875,3.396,5.448,5.5,9.333,5.5s7.458-2.104,9.333-5.5l140.896-254.813c13.375-24.76,20.438-52.771,20.438-81.021    C426.667,76.563,350.104,0,256,0z M256,256c-47.052,0-85.333-38.281-85.333-85.333c0-47.052,38.281-85.333,85.333-85.333    s85.333,38.281,85.333,85.333C341.333,217.719,303.052,256,256,256z",
            fillColor: "#0066D3",
            fillOpacity: 1,
            strokeWeight: 1,
            strokeColor: "#fff",
            rotation: 0,
            scale: 0.07,
            //anchor: new google.maps.Point(15, 30),
        };

        const travelModes = ['DRIVING', 'BICYCLING', 'WALKING', 'TRANSIT'];
        const transitModes = ['BUS', 'RAIL', 'SUBWAY', 'TRAIN', 'TRAM'];
        const trafficModels = ['bestguess', 'pessimistic', 'optimistic'];
        var app = new Vue({
            el: '#vc_app',
            data: {
                map: {},
                geocoder: {},
                service: {},
                bounds: {},
                currentMarkerLatlng: null,
                currentMarker: null,
                markersArray: [],
                travelModes: travelModes,
                trafficModels: trafficModels,
                transitModes: transitModes,
                travelMode: '',
                currentTravelMode: 'DRIVING',
                currentTransitMode: 'BUS',
                drivingOptions: { departureTime: '', trafficModel: 'bestguess' },
                destinations: '',
                departureTime: '',
                minDateForDeparture: '',
                result: [],
                modelTable: {
                    pageSettings: {
                        pageSizes: [10, 20, 50, 100],
                        pageSize: 10,
                        pageCount: 5
                    }
                },
                distanceGridToolbar: ['Search', 'ExcelExport'],
                statisticsGridToolbar: ['ExcelExport'],
                takeAddressToCalculate: 10,
                destinationName: '',
                statistics: []
            },
            mounted: function () {
                this.minDateForDeparture = new Date(Date.now() + 10000);

                this.destinations = window.localStorage.getItem('destinations');
                this.map = new google.maps.Map(document.getElementById("map"), {
                    center: { lat: 59.32489359908779, lng: 18.071498668311246 },
                    zoom: 10,
                });
                // initialize services
                this.geocoder = new google.maps.Geocoder();
                this.service = new google.maps.DistanceMatrixService();

                this.bounds = new google.maps.LatLngBounds();
                this.map.addListener("click", (mapsMouseEvent) => {
                    if (this.currentMarker) {
                        this.currentMarker.setMap(null);
                        this.currentMarker = null;
                    }

                    this.result = [];

                    this.currentMarkerLatlng = null;

                    this.currentMarker = new google.maps.Marker({
                        map: this.map,
                        position: mapsMouseEvent.latLng,
                        label: '',
                        icon: 'http://maps.google.com/mapfiles/kml/paddle/blu-blank.png'
                    });

                    this.deleteMarkers();

                    this.currentMarkerLatlng = mapsMouseEvent.latLng;


                });

            },
            computed: {
                destinationList: function () {
                    if (!this.destinations) return [];

                    const destinations = this.destinations.split('\n');

                    return destinations;
                }
            },
            methods: {
                calculateTime(originLatLng, skip) {

                    let destinations = this.skipTake(this.destinationList, skip, this.takeAddressToCalculate);
                    if (destinations.length > 0) {
                        const request = {
                            origins: destinations,
                            destinations: [originLatLng],
                            travelMode: this.currentTravelMode,
                            unitSystem: google.maps.UnitSystem.METRIC,
                            avoidHighways: false,
                            avoidTolls: false
                        };

                        //if (this.travelMode == 'DRIVING') {
                        //    request.drivingOptions = {
                        //        departureTime: this.drivingOptions.departureTime ? this.drivingOptions.departureTime : new Date(Date.now() + 100000),  // for the time N milliseconds from now.
                        //        trafficModel: this.drivingOptions.trafficModel
                        //    }
                        //}

                        //if (this.travelMode == 'TRANSIT') {
                        //    request.transitOptions = {
                        //        departureTime: new Date(Date.now() + 100000),
                        //        modes: ['BUS','RAIL','SUBWAY','TRAIN','TRAM']
                        //    }
                        //}

                        if (!this.travelMode) {
                            if (this.currentTravelMode == 'DRIVING') {
                                request.drivingOptions = {
                                    departureTime: this.departureTime ? this.departureTime : new Date(Date.now() + 100000),  // for the time N milliseconds from now.
                                    trafficModel: this.drivingOptions.trafficModel
                                }
                            }

                            if (this.currentTravelMode == 'TRANSIT') {
                                request.transitOptions = {
                                    //departureTime: new Date(Date.now() + 100000),
                                    modes: [this.currentTransitMode]
                                }

                                if (this.departureTime) {
                                    request.transitOptions.departureTime = this.departureTime;
                                }
                            }
                        }

                        this.service.getDistanceMatrix(request).then((response) => {

                            const originList = response.originAddresses;
                            const destinationList = response.destinationAddresses;

                            this.destinationName = destinationList[0];

                            console.log('ORIGIN LIST')
                            console.log(originList)


                            const showGeocodedAddressOnMap = (asDestination) => {

                                const handler = ({ results }) => {
                                    this.map.fitBounds(_bounds.extend(results[0].geometry.location));
                                    this.markersArray.push(
                                        new google.maps.Marker({
                                            map: this.map,
                                            position: results[0].geometry.location,
                                            label: asDestination ? "D" : "O",
                                        })
                                    );
                                };


                                return handler;
                            };

                            for (let i = 0; i < originList.length; i++) {
                                const results = response.rows[i].elements;

                                for (let j = 0; j < results.length; j++) {

                                    if (this.currentTravelMode == 'DRIVING') {
                                        this.result.push({
                                            origin: originList[i],
                                            destination: originList[i],
                                            drivingDistance: results[j].distance.text.replace('.', ','),
                                            drivingDistanceInMeters: results[j].distance.value,
                                            drivingDistanceInKm: (parseFloat(results[j].distance.value) / 1000).toFixed(2).toString().replace('.', ','),
                                            drivingTime: results[j].duration.text,
                                            drivingTimeInSeconds: parseInt(results[j].duration.value),
                                            drivingTimeInMin: parseFloat((parseFloat(results[j].duration.value) / 60).toFixed(0)),

                                            walkingDistance: '',
                                            walkingDistanceInMeters: '',
                                            walkingDistanceInKm: 0,
                                            walkingTime: '',
                                            walkingTimeInSeconds: '',
                                            walkingTimeInMin: 0,

                                            bicyclingDistance: '',
                                            bicyclingDistanceInMeters: '',
                                            bicyclingDistanceInKm: 0,
                                            bicyclingTime: '',
                                            bicyclingTimeInSeconds: '',
                                            bicyclingTimeInMin: 0,

                                            busDistance: '',
                                            busDistanceInMeters: '',
                                            busDistanceInKm: 0,
                                            busTime: '',
                                            busTimeInSeconds: '',
                                            busTimeInMin: 0,

                                            subwayDistance: '',
                                            subwayDistanceInMeters: '',
                                            subwayDistanceInKm: 0,
                                            subwayTime: '',
                                            subwayTimeInSeconds: '',
                                            subwayTimeInMin: 0,

                                            trainDistance: '',
                                            trainDistanceInMeters: '',
                                            trainDistanceInKm: 0,
                                            trainTime: '',
                                            trainTimeInSeconds: '',
                                            trainTimeInMin: 0,

                                            railDistance: '',
                                            railDistanceInMeters: '',
                                            railDistanceInKm: 0,
                                            railTime: '',
                                            railTimeInSeconds: '',
                                            railTimeInMin: 0,

                                            tramDistance: '',
                                            tramDistanceInMeters: '',
                                            tramDistanceInKm: 0,
                                            tramTime: '',
                                            tramTimeInSeconds: '',
                                            tramTimeInMin: 0,
                                        })
                                    }
                                    else {
                                        const currentOrigin = this.result[i + skip];
                                        if (this.currentTravelMode == 'TRANSIT') {
                                            currentOrigin[`${this.currentTransitMode.toLowerCase()}Distance`] = results[j].distance?.text.replace('.', ',');
                                            currentOrigin[`${this.currentTransitMode.toLowerCase()}DistanceInMeters`] = results[j].distance?.value;
                                            currentOrigin[`${this.currentTransitMode.toLowerCase()}DistanceInKm`] = results[j].distance ? (parseFloat(results[j].distance.value) / 1000).toFixed(2).toString().replace('.', ',') : 0;

                                            currentOrigin[`${this.currentTransitMode.toLowerCase()}Time`] = results[j].duration?.text;
                                            currentOrigin[`${this.currentTransitMode.toLowerCase()}TimeInSeconds`] = results[j].duration?.value;
                                            currentOrigin[`${this.currentTransitMode.toLowerCase()}TimeInMin`] = results[j].duration ? parseFloat((parseFloat(results[j].duration.value) / 60).toFixed(0)) : 0;
                                        } else {
                                            currentOrigin[`${this.currentTravelMode.toLowerCase()}Distance`] = results[j].distance?.text.replace('.', ',');
                                            currentOrigin[`${this.currentTravelMode.toLowerCase()}DistanceInMeters`] = results[j].distance?.value;
                                            currentOrigin[`${this.currentTravelMode.toLowerCase()}DistanceInKm`] = results[j].distance ? (parseFloat(results[j].distance.value) / 1000).toFixed(2).toString().replace('.', ',') : 0;

                                            currentOrigin[`${this.currentTravelMode.toLowerCase()}Time`] = results[j].duration?.text;
                                            currentOrigin[`${this.currentTravelMode.toLowerCase()}TimeInSeconds`] = results[j].duration?.value;
                                            currentOrigin[`${this.currentTravelMode.toLowerCase()}TimeInMin`] = results[j].duration ? parseFloat((parseFloat(results[j].duration.value) / 60).toFixed(0)) : 0;
                                        }
                                    }
                                    var locationDistanceGrid = document.getElementById("locationDistances").ej2_instances[0];
                                    locationDistanceGrid.refresh();
                                }
                            }
                        });

                        setTimeout(() => {
                            this.calculateTime(originLatLng, skip + this.takeAddressToCalculate);
                        }, 2000);

                    }
                    else {
                        if (this.currentTravelMode == 'TRANSIT' && this.currentTransitMode == 'TRAM') {
                            this.calculateStatistics();
                            this.unBlockUI();
                        } else {

                            if (this.currentTravelMode == 'TRANSIT') {
                                const currentTransitModeIndex = this.transitModes.findIndex(x => x == this.currentTransitMode);
