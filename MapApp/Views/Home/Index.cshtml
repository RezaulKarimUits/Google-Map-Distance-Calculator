                            </div>

                            <div class="form-group col-4" v-if="travelMode=='TRANSIT'">
                                <label for="departureTime">Departure time</label>
                                <ejs-datetimepicker :min="minDateForDeparture" v-model="transitOptions.arrivalTime" :placeholder="'Arrival time'"></ejs-datetimepicker>
                            </div>

                            <div class="form-group col-4" v-if="travelMode=='TRANSIT'">
                                <label for="departureTime">Departure time</label>
                                <ejs-datetimepicker :min="minDateForDeparture" v-model="transitOptions.departureTime" :placeholder="'Departure time'"></ejs-datetimepicker>
                            </div>*@

                    </div>

                    <div class="form-row">
                        <div class="form-group col-12">
                            <label for="destinations">Origins</label>
                            <textarea class="form-control form-control-sm" id="destinations" v-model="destinations" rows="6" v-validate="'required'" name="destinations" :class="{'is-invalid': errors.has('frmModel.destinations')}"></textarea>
                            <div class="invalid-feedback" :class="{'d-block': errors.has('frmModel.destinations')}">
                                Please enter location names
                            </div>
                        </div>

                    </div>

                    <div id="map"></div>
                    <div class="mt-3">
                        <button class="btn btn-primary" type="submit">Calculate</button>
                        <button class="btn btn-secondary" type="button" @@click="clearFilter">Clear</button>
                        <button class="btn btn-secondary" type="button" @@click="clearAll">Clear All</button>
                    </div>
                </form>
            </div>
